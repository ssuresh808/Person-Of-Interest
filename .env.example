# Copy to .env and fill in.

# Kaggle credentials for CelebA download (optional — can also use ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=

# HuggingFace token, only needed if you hit rate limits or want gated models
HF_TOKEN=

# Optional override for cache locations
HF_HOME=~/.cache/huggingface
TRANSFORMERS_CACHE=~/.cache/huggingface/hub

# Logging
LOG_LEVEL=INFO

# UI host/port for NiceGUI server
POI_HOST=0.0.0.0
POI_PORT=8080
